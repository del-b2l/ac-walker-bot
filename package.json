{
  "name": "walker-app",
  "version": "1.0.0",
  "description": "Walker from Animal Crossing - local chatbot app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.batool.walker-app",
    "productName": "Walker's Abode",
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "walker_lore.txt",
      "node_modules/**"
    ]
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "groq-sdk": "^0.3.0"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0",
    "electron": "^28.0.0"
  }
}